{
    "label": "lock",
    "action": "pkill -x wlogout; ~/.config/waybar/scripts/lock-screen.sh",
    "text": "Lock",
    "keybind": "l"
}

{
    "label": "suspend",
    "action": "pkill -x wlogout; ~/.config/waybar/scripts/suspend-now.sh",
    "text": "Sleep",
    "keybind": "s"
}

{
    "label": "logout",
    "action": "pkill -x wlogout; niri msg action quit",
    "text": "Logout",
    "keybind": "e"
}

{
    "label": "shutdown",
    "action": "pkill -x wlogout; ~/.config/waybar/scripts/wallpaper.sh current; ~/.config/waybar/scripts/caffeine-control.sh stop; systemctl poweroff",
    "text": "Shutdown",
    "keybind": "p"
}

{
    "label": "reboot",
    "action": "pkill -x wlogout; ~/.config/waybar/scripts/wallpaper.sh current; ~/.config/waybar/scripts/caffeine-control.sh stop; systemctl reboot",
    "text": "Reboot",
    "keybind": "r"
}

# Mako notification daemon config (Wayland-native)
# Monochrome theme

font=JetBrainsMono Nerd Font 10
background-color=#141414dd
text-color=#d4d4d4
border-color=#b0b0b0
border-size=2
border-radius=8
width=350
height=120
margin=4
padding=12
default-timeout=5000
max-visible=3
layer=overlay
anchor=top-right
icon-path=/usr/share/icons/Papirus-Dark

[urgency=low]
background-color=#141414dd
border-color=#666666

[urgency=normal]
background-color=#141414dd
border-color=#b0b0b0

[urgency=critical]
background-color=#141414dd
border-color=#ffffff
default-timeout=0
